# Backend Production Environment Variables
# Copy this to .env and fill in real values (never commit .env)

# Server
NODE_ENV=production
PORT=3001

# MongoDB (Atlas)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/sispatnaist?retryWrites=true&w=majority

# JWT
JWT_SECRET=<sua-chave-secreta-muito-longa-e-segura>
JWT_REFRESH_SECRET=<outra-chave-secreta-diferente>         # Opcional, fallback para JWT_SECRET
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# CORS — múltiplas origens separadas por vírgula (frontend em produção + dev local)
CORS_ORIGIN=https://sispnaist-1-0.vercel.app,http://localhost:3000

# Frontend URL (para links em e-mails)
FRONTEND_URL=https://sispnaist-1-0.vercel.app

# Email (SMTP / Brevo / Resend)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=seu-email@gmail.com
EMAIL_PASS=sua-senha-de-app
EMAIL_FROM="SISPNAIST" <noreply@seudominio.com>

# Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads
