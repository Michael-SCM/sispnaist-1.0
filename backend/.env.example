# ──────────────────────────────────────────────
# SISPNAIST Backend - Variáveis de Ambiente
# ──────────────────────────────────────────────

# Servidor
PORT=3001
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/sispnaist

# JWT (segredos)
JWT_SECRET=seu_segredo_aqui_mude_em_producao
JWT_REFRESH_SECRET=seu_refresh_secret_aqui_mude_em_producao
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:3000,https://sispnaist-1-0.vercel.app

# Frontend URL (para links de email)
FRONTEND_URL=http://localhost:5173

# Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# ──────────────────────────────────────────────
# E-mail (Nodemailer)
# ──────────────────────────────────────────────
EMAIL_HOST=smtp.seudominio.com
EMAIL_PORT=587
EMAIL_USER=seu@email.com
EMAIL_PASS=sua_senha
EMAIL_FROM=noreply@sispnaist.com

# ──────────────────────────────────────────────
# Integração com APIs Externas (Ministério da Saúde)
# ──────────────────────────────────────────────
