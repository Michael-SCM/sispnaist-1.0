# Frontend Production Environment
# Em produção (Vercel), a URL da API é relativa pois o proxy do vercel.json
# redireciona /api/* para o backend no Render.
# Em desenvolvimento, defina VITE_API_URL=http://localhost:3001/api

# API Backend URL
VITE_API_URL=/api

# Production flags
VITE_NODE_ENV=production
